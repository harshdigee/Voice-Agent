# ==== Required ====
PORT=5010
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.dev

# Twilio config
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
OUTBOUND_TO_NUMBER=+91xxxxxxxxxx
TWILIO_VOICE_LANGUAGE=en-IN
TWILIO_VOICE_HINTS=sales,representatives,leads,clients,active,present,count,list

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Your Business API (returns list of users/sales reps)
SALESREP_API_URL=https://api.example.com/api/user/all-users
SALESREP_API_AUTH_TYPE=none
SALESREP_API_BEARER=
SALESREP_API_HEADER_KEY=
SALESREP_API_HEADER_VALUE=
